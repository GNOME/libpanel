msgid "Open Pages"
msgstr "Otwarte strony"

#: src/panel-frame.ui:62
msgid "Frame"
msgstr "Ramka"

#: src/panel-frame.ui:64
msgid "Move Page _Left"
msgstr "Prze_nieś stronę w lewo"

#: src/panel-frame.ui:69
